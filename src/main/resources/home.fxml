<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" alignment="CENTER" prefHeight="203.0" prefWidth="388.0" spacing="20.0" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.examenra5.HomeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Label text="Playlist ID" />
   <TextField fx:id="playlistIdTextField" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="50.0" />
    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
        <Button onAction="#onOpenButtonAction" styleClass="open-button" text="Abrir informe" />
        <Button layoutX="10.0" layoutY="10.0" onAction="#onCloseButtonAction" styleClass="close-button" text="Cerrar informe" />
    </HBox>
</VBox>
